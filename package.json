{
  "name": "@langchain/langsmith-codex-plugins",
  "version": "0.0.0",
  "description": "OpenAI Codex Plugins for LangSmith",
  "keywords": [
    "codex",
    "langsmith",
    "openai"
  ],
  "homepage": "https://github.com/langchain-ai/langsmith-codex-plugins#readme",
  "bugs": {
    "url": "https://github.com/langchain-ai/langsmith-codex-plugins/issues"
  },
  "license": "MIT",
  "author": "LangChain",
  "repository": {
    "type": "git",
    "url": "https://github.com/langchain-ai/langsmith-codex-plugins.git"
  },
  "files": [
    ".codex-plugin",
    "hooks",
    "dist",
    "README.md"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown --config plugins/tracing/tsdown.config.ts",
    "test": "vitest",
    "format": "oxfmt",
    "lint:dist": "pnpm run build && git diff --exit-code -- plugins/tracing/dist/index.mjs",
    "lint:oxfmt": "oxfmt --check",
    "lint:tsc": "tsc --noEmit",
    "lint": "pnpm run lint:oxfmt && pnpm run lint:tsc && pnpm run lint:dist"
  },
  "dependencies": {
    "langsmith": "^0.6.0",
    "uuid": "^14.0.0",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "memfs": "^4.57.2",
    "oxfmt": "^0.46.0",
    "tsdown": "^0.21.10",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.33.0"
}
